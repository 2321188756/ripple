{
  "name": "send-email",
  "version": "1.0.0",
  "description": "发送邮件。用 smtplib，SMTP 凭证存 config.json。端口 465 走 SSL，587/25 走 STARTTLS。",
  "author": "Ripple",
  "runtime": "python",
  "entry": "send_email.py",
  "mode": "tool",
  "tools": [
    {
      "name": "send_email",
      "description": "发送邮件。需先在 plugins/send-email/config.json 配置 SMTP 凭证。",
      "parameters": {
        "type": "object",
        "properties": {
          "to": { "type": "string", "description": "收件人邮箱" },
          "subject": { "type": "string", "description": "邮件主题" },
          "body": { "type": "string", "description": "邮件正文（纯文本）" }
        },
        "required": ["to", "subject", "body"]
      }
    }
  ],
  "permissions": ["network"],
  "config_schema": {
    "type": "object",
    "properties": {
      "smtp_host": { "type": "string", "description": "SMTP 服务器（如 smtp.qq.com）" },
      "smtp_port": { "type": "integer", "description": "端口（465=SSL，587=STARTTLS）", "default": 465 },
      "smtp_user": { "type": "string", "description": "发件邮箱账号" },
      "smtp_pass": { "type": "string", "description": "SMTP 授权码（非邮箱密码）" },
      "from_name": { "type": "string", "description": "发件人显示名", "default": "Ripple" }
    }
  }
}
